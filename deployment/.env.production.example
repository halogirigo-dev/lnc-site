# ── Production Environment Template ───────────────────────────
# Copy to /var/www/lnc/public_html/.env on the server
# NEVER commit real credentials to git

# Midtrans (get from dashboard.midtrans.com > Settings > Access Keys)
MIDTRANS_SERVER_KEY=Mid-server-REPLACE_WITH_REAL_KEY
MIDTRANS_CLIENT_KEY=Mid-client-REPLACE_WITH_REAL_KEY
MIDTRANS_IS_PRODUCTION=true

# PostgreSQL (created during VPS setup)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=lnc_production
DB_USER=lnc_user
DB_PASS=REPLACE_WITH_STRONG_PASSWORD

# Site
SITE_URL=https://lomboknatureculture.com

# Deploy webhook secret (generate with: openssl rand -hex 32)
DEPLOY_SECRET=REPLACE_WITH_RANDOM_SECRET
